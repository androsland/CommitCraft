{
  "name": "git-commitcraft",
  "displayName": "CommitCraft - AI Commit Messages Helper",
  "description": "Generate Git commit messages using AI (Claude or Ollama)",
  "version": "0.1.3",
  "publisher": "androsland",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/androsland/CommitCraft.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-commitcraft.generate",
        "title": "CommitCraft: Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "command": "git-commitcraft.generating",
        "title": "CommitCraft: Generating...",
        "icon": "$(loading~spin)"
      },
      {
        "command": "git-commitcraft.setApiKey",
        "title": "CommitCraft: Set API Key"
      },
      {
        "command": "git-commitcraft.editApiKey",
        "title": "CommitCraft: Edit API Key"
      },
      {
        "command": "git-commitcraft.selectModel",
        "title": "CommitCraft: Select Model"
      },
      {
        "command": "git-commitcraft.deleteApiKey",
        "title": "CommitCraft: Delete API Key"
      }
    ],
    "configuration": {
      "title": "CommitCraft",
      "properties": {
        "git-commitcraft.provider": {
          "type": "string",
          "enum": [
            "claude",
            "ollama"
          ],
          "markdownEnumDescriptions": [
            "Anthropic Claude API. Requires an API key — run **CommitCraft: Set API Key** from the Command Palette to store it securely.",
            "Local Ollama instance. Free, no API key needed. Ollama must be running on this machine (or at the configured host URL)."
          ],
          "default": "claude",
          "markdownDescription": "AI provider for commit message generation. Switch between **Claude** (cloud) and **Ollama** (local)."
        },
        "git-commitcraft.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL. The default works for a standard local installation."
        },
        "git-commitcraft.ollamaModel": {
          "type": "string",
          "default": "",
          "markdownDescription": "The Ollama model to use. Click the model indicator in the status bar (bottom-right) or run **CommitCraft: Select Model** from the Command Palette to pick from your installed models. The chosen model is saved here automatically."
        }
      }
    },
    "menus": {
      "scm/title": [
        {
          "command": "git-commitcraft.generate",
          "group": "navigation",
          "when": "!git-commitcraft.isGenerating"
        },
        {
          "command": "git-commitcraft.generating",
          "group": "navigation",
          "when": "git-commitcraft.isGenerating"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
